# Coda API Configuration
# Get your API token from: https://coda.io/account

CODA_API_TOKEN=your_api_token_here

# Document IDs (comma-separated)
# Find doc ID in URL: https://coda.io/d/_dABCDEFGH -> use ABCDEFGH
# Example: DOC_IDS=AbCDeFGH,XyZ123456,PqRsTuVwX

DOC_IDS=your_doc_id_1,your_doc_id_2,your_doc_id_3
